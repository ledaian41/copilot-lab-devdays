@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-green-600 text-xs">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-1 text-center border border-[#8B4513] rounded transition-all duration-150 select-none min-h-[60px] text-xs leading-tight shadow-sm";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "bg-amber-200 border-amber-400 text-amber-900"
                : "bg-[#90EE90] border-[#8B4513] text-green-800"
            : "bg-[#FFFDD0] text-gray-700 active:bg-[#F5F5DC]";

        var freeSpaceClasses = Square.IsFreeSpace ? "font-bold text-sm" : "";

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }
}
